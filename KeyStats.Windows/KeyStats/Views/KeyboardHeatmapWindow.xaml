<Window x:Class="KeyStats.Views.KeyboardHeatmapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:KeyStats.Views.Controls"
        Title="键盘热力图"
        Width="860"
        Height="460"
        MinWidth="860"
        MinHeight="460"
        MaxWidth="860"
        MaxHeight="460"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SurfaceBrush}"
        ShowInTaskbar="True">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="TitleText"
                       Text="键盘热力图"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock x:Name="SubtitleText"
                       Text="按日期查看键盘热区，仅展示聚合计数，不记录输入内容"
                       Margin="0,4,0,0"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button x:Name="PrevDayButton"
                        Content="前一天"
                        Style="{DynamicResource GhostButton}"
                        Padding="12,5"
                        Margin="0,0,8,0"
                        Click="ShowPreviousDay_Click"/>
                <Button x:Name="NextDayButton"
                        Content="后一天"
                        Style="{DynamicResource GhostButton}"
                        Padding="12,5"
                        Click="ShowNextDay_Click"/>
            </StackPanel>

            <TextBlock x:Name="DateText"
                       Grid.Column="1"
                       Margin="12,0,12,0"
                       VerticalAlignment="Center"
                       FontFamily="Consolas"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Text="--"/>

            <Button x:Name="BackToTodayButton"
                    Grid.Column="2"
                    Content="回到今天"
                    Style="{DynamicResource GhostButton}"
                    Padding="12,5"
                    Click="BackToToday_Click"
                    Visibility="Collapsed"/>

            <TextBlock x:Name="SummaryText"
                       Grid.Column="3"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="12,10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Direction="270"/>
            </Border.Effect>

            <Grid x:Name="HeatmapAnimationHost" ClipToBounds="True">
                <Image x:Name="PreviousSnapshotImage"
                       Stretch="Fill"
                       Visibility="Collapsed"
                       IsHitTestVisible="False">
                    <Image.RenderTransform>
                        <TranslateTransform x:Name="PreviousLayerTransform"/>
                    </Image.RenderTransform>
                </Image>

                <Grid x:Name="CurrentHeatmapLayer">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="CurrentLayerTransform"/>
                    </Grid.RenderTransform>

                    <controls:KeyboardHeatmapControl x:Name="KeyboardHeatmapView"
                                                     MinHeight="320"/>

                    <Border x:Name="EmptyOverlay"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource DividerBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Opacity="0.62"
                            Visibility="Collapsed"/>

                    <Border x:Name="EmptyBadge"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            CornerRadius="14"
                            BorderBrush="{DynamicResource DividerBrush}"
                            BorderThickness="1"
                            Padding="18,12"
                            Visibility="Collapsed">
                        <Border.Background>
                            <SolidColorBrush Color="#CCFFFFFF"/>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE765;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="EmptyBadgeText"
                                       Text="当天暂无键盘数据"
                                       Margin="8,0,0,0"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
