<Window x:Class="KeyStats.Views.KeyboardHeatmapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:KeyStats.Views.Controls"
        Title="键盘热力图"
        Width="860"
        Height="460"
        MinWidth="860"
        MinHeight="460"
        MaxWidth="860"
        MaxHeight="460"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SurfaceBrush}"
        ShowInTaskbar="True">
    <Window.Resources>
        <Style x:Key="CalendarHeaderButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="CalendarNavButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="StretchCalendarItemStyle" TargetType="{x:Type CalendarItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CalendarItem}">
                        <Grid x:Name="PART_Root" SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="4,2,4,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="PART_PreviousButton"
                                        Grid.Column="0"
                                        Style="{StaticResource CalendarNavButtonStyle}"
                                        Content="&#xE76B;"/>
                                <Button x:Name="PART_HeaderButton"
                                        Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        Style="{StaticResource CalendarHeaderButtonStyle}"/>
                                <Button x:Name="PART_NextButton"
                                        Grid.Column="2"
                                        Style="{StaticResource CalendarNavButtonStyle}"
                                        Content="&#xE76C;"/>
                            </Grid>

                            <Grid x:Name="PART_MonthView"
                                  Grid.Row="1"
                                  Margin="2,0,2,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                            </Grid>

                            <Grid x:Name="PART_YearView"
                                  Grid.Row="1"
                                  Visibility="Collapsed"
                                  Margin="2,0,2,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                            </Grid>

                            <Rectangle x:Name="PART_DisabledVisual"
                                       Grid.RowSpan="2"
                                       Fill="#A5FFFFFF"
                                       Visibility="Collapsed"
                                       IsHitTestVisible="False"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PART_DisabledVisual" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType={x:Type Calendar}}}" Value="Year">
                                <Setter TargetName="PART_MonthView" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="PART_YearView" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource AncestorType={x:Type Calendar}}}" Value="Decade">
                                <Setter TargetName="PART_MonthView" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="PART_YearView" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="TitleText"
                       Text="键盘热力图"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock x:Name="SubtitleText"
                       Text="按日期查看键盘热区，仅展示聚合计数，不记录输入内容"
                       Margin="0,4,0,0"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button x:Name="PrevDayButton"
                        Content="前一天"
                        Style="{DynamicResource GhostButton}"
                        Padding="12,5"
                        Margin="0,0,8,0"
                        Click="ShowPreviousDay_Click"/>
                <Button x:Name="NextDayButton"
                        Content="后一天"
                        Style="{DynamicResource GhostButton}"
                        Padding="12,5"
                        Click="ShowNextDay_Click"/>
            </StackPanel>

            <Button x:Name="DatePickerButton"
                    Grid.Column="1"
                    Margin="12,0,12,0"
                    Style="{DynamicResource GhostButton}"
                    Padding="10,5"
                    Click="OpenDatePicker_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE787;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="DateText"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               FontFamily="Consolas"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Text="--"/>
                </StackPanel>
            </Button>

            <Button x:Name="BackToTodayButton"
                    Grid.Column="2"
                    Content="回到今天"
                    Style="{DynamicResource GhostButton}"
                    Padding="12,5"
                    Click="BackToToday_Click"
                    Visibility="Collapsed"/>

            <TextBlock x:Name="SummaryText"
                       Grid.Column="3"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"/>

            <Popup x:Name="DatePickerPopup"
                   PlacementTarget="{Binding ElementName=DatePickerButton}"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade"
                   Closed="DatePickerPopup_Closed">
                <Border Margin="0,6,0,0"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource DividerBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <Calendar x:Name="DatePickerCalendar"
                              SelectionMode="SingleDate"
                              DisplayMode="Month"
                              Background="Transparent"
                              BorderThickness="0"
                              Margin="4"
                              CalendarItemStyle="{StaticResource StretchCalendarItemStyle}"
                              SelectedDatesChanged="DatePickerCalendar_SelectedDatesChanged">
                        <Calendar.LayoutTransform>
                            <ScaleTransform ScaleX="1.12" ScaleY="1.12"/>
                        </Calendar.LayoutTransform>
                        <Calendar.CalendarDayButtonStyle>
                                <Style TargetType="{x:Type CalendarDayButton}">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="Opacity" Value="1"/>
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="VerticalAlignment" Value="Stretch"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsBlackedOut" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                            <Setter Property="Opacity" Value="0.55"/>
                                        </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Calendar.CalendarDayButtonStyle>
                    </Calendar>
                </Border>
            </Popup>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="12,10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Direction="270"/>
            </Border.Effect>

            <Grid x:Name="HeatmapAnimationHost" ClipToBounds="True">
                <Image x:Name="PreviousSnapshotImage"
                       Stretch="Fill"
                       Visibility="Collapsed"
                       IsHitTestVisible="False">
                    <Image.RenderTransform>
                        <TranslateTransform x:Name="PreviousLayerTransform"/>
                    </Image.RenderTransform>
                </Image>

                <Grid x:Name="CurrentHeatmapLayer">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="CurrentLayerTransform"/>
                    </Grid.RenderTransform>

                    <controls:KeyboardHeatmapControl x:Name="KeyboardHeatmapView"/>

                    <Border x:Name="EmptyOverlay"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource DividerBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Opacity="0.62"
                            Visibility="Collapsed"/>

                    <Border x:Name="EmptyBadge"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            CornerRadius="14"
                            BorderBrush="{DynamicResource DividerBrush}"
                            BorderThickness="1"
                            Padding="18,12"
                            Visibility="Collapsed">
                        <Border.Background>
                            <SolidColorBrush Color="#CCFFFFFF"/>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE765;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="EmptyBadgeText"
                                       Text="当天暂无键盘数据"
                                       Margin="8,0,0,0"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
